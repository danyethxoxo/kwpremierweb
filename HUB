    .cal-day.sala-day .cal-day-toggle:not(.is-today-green):hover { background: #f0fdf4; }

    /* El documento en sí — fiel al Word original */
    .contrato-doc {
      background: #fff;
      width: 100%;
      max-width: 740px;
      min-height: 960px;
      padding: 18px 48px 36px 48px;
      box-shadow: 0 4px 24px rgba(0,0,0,0.12);
      border-radius: 2px;
      font-family: Arial, sans-serif;
      font-size: 10pt;
      line-height: 1.5;
      color: #000;
    }

    /* Header con logo */
    .doc-header {
      margin-bottom: 10px;
    }
    .doc-header img {
      height: 38px;
      width: auto;
    }

    .doc-titulo {
      text-align: center;
      font-weight: 700;
      font-size: 11pt;
      letter-spacing: 0.25em;
      margin: 0 0 14px;
      text-decoration: underline;
      font-family: Georgia, serif;
    }

    .doc-intro {
      text-align: justify;
      margin-bottom: 12px;
      font-size: 10pt;
    }

    .doc-seccion {
      font-weight: 700;
      margin: 14px 0 5px;
      text-decoration: underline;
      font-size: 10pt;
    }

    .doc-clausula-titulo {
      font-weight: 700;
      margin-top: 12px;
      display: inline;
      font-size: 10pt;
    }

    .doc-p {
      text-align: justify;
      margin-bottom: 5px;
      font-size: 10pt;
    }

    .doc-lista {
      margin: 3px 0 5px 22px;
    }
    .doc-lista li {
      margin-bottom: 3px;
      text-align: justify;
      font-size: 10pt;
    }

    .doc-campo {
      font-weight: 700;
      border-bottom: 1px solid #CC0000;
      color: #CC0000;
    }
    .doc-campo.filled {
      color: #000;
      border-bottom: none;
      font-weight: 700;
    }

    /* Firmas — dos columnas con líneas */
    .doc-firmas-wrap {
      margin-top: 20px;
    }
    .doc-firmas-row {
      display: flex;
      gap: 0;
      margin-bottom: 16px;
    }
    .doc-firma-col {
      flex: 1;
      text-align: center;
      font-size: 9pt;
      line-height: 1.4;
      padding: 0 10px;
    }
    .doc-firma-linea-top {
      border-top: 1px solid #000;
      padding-top: 5px;
      margin-top: 28px;
    }
    .doc-firma-bold { font-weight: 700; font-size: 9pt; }

    /* Placeholder vacío */
    .acuerdos-empty {
      display: flex; flex-direction: column;
      align-items: center; justify-content: center;
