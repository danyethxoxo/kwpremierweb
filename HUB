    /* Overlay de pantalla completa para acuerdos */
    .acuerdos-overlay {
      display: none;
      position: fixed;
      inset: 0;
      background: var(--bg);
      z-index: 300;
      flex-direction: column;
      overflow: hidden;
    }
    .acuerdos-overlay.open { display: flex; }

    .acuerdos-topbar {
      height: 52px;
      background: #fff;
      border-bottom: 1px solid var(--border);
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 0 20px;
      flex-shrink: 0;
    }
    .acuerdos-topbar-left { display: flex; align-items: center; gap: 12px; }
    .btn-back {
      display: flex; align-items: center; gap: 6px;
      background: none; border: none; cursor: pointer;
      font-size: 13px; font-weight: 600; color: var(--muted);
      font-family: 'DM Sans', sans-serif;
      transition: color 0.15s;
      padding: 0;
    }
    .btn-back:hover { color: var(--text); }
    .acuerdos-topbar-title {
      font-size: 14px; font-weight: 700; color: var(--text);
    }

    /* Grid: selector izq + editor/preview der */
    .acuerdos-body {
      flex: 1;
      display: grid;
      grid-template-columns: 260px 1fr 1fr;
      overflow: hidden;
      gap: 0;
    }

    /* Columna 1: lista de acuerdos */
    .acuerdos-sidebar {
      background: #fff;
      border-right: 1px solid var(--border);
      overflow-y: auto;
      padding: 14px 12px;
    }
    .acuerdos-sidebar-label {
      font-size: 10px; font-weight: 700;
      letter-spacing: 0.12em; text-transform: uppercase;
      color: #bbb; margin: 0 4px 8px; display: block;
    }
    .acuerdo-item {
      display: flex; align-items: flex-start; gap: 10px;
      padding: 11px 10px; border-radius: 10px;
      cursor: pointer; transition: background 0.12s;
      border: 1.5px solid transparent;
      margin-bottom: 5px;
    }
    .acuerdo-item:hover { background: var(--bg); }
    .acuerdo-item.active {
      background: #fff0f0;
      border-color: rgba(204,0,0,0.15);
    }
    .acuerdo-item-icon {
      width: 34px; height: 34px; border-radius: 8px;
      display: flex; align-items: center; justify-content: center;
      font-size: 16px; flex-shrink: 0;
    }
    .acuerdo-item-info { flex: 1; min-width: 0; }
    .acuerdo-item-name {
      font-size: 12.5px; font-weight: 700; color: var(--text);
      line-height: 1.3;
    }
    .acuerdo-item-desc {
      font-size: 11px; color: var(--muted); margin-top: 2px;
    }

    /* Columna 2: formulario */
    .acuerdos-form-col {
      border-right: 1px solid var(--border);
      overflow-y: auto;
      padding: 20px;
      background: var(--bg);
    }
    .acuerdos-form-title {
      font-size: 13px; font-weight: 700; color: var(--text);
      margin-bottom: 4px;
    }
    .acuerdos-form-sub {
      font-size: 11px; color: var(--muted); margin-bottom: 18px;
    }
    .acuerdo-field { margin-bottom: 14px; }
    .acuerdo-field label {
      display: block;
      font-size: 12px; font-weight: 700;
      letter-spacing: 0.04em; text-transform: uppercase;
      color: #CC0000; margin-bottom: 5px;
    }
    .acuerdo-field input,
    .acuerdo-field textarea {
      width: 100%; padding: 9px 12px;
      border: 1.5px solid var(--border);
      border-radius: 10px;
      font-size: 13px; font-family: 'DM Sans', sans-serif;
      color: var(--text); background: #fff;
      transition: border-color 0.15s, box-shadow 0.15s;
      outline: none;
    }
    .acuerdo-field input:focus,
    .acuerdo-field textarea:focus {
      border-color: var(--red);
      box-shadow: 0 0 0 3px rgba(204,0,0,0.08);
    }
    .acuerdo-field .monto-letra-display {
      margin-top: 5px;
      font-size: 11px; color: #888; font-style: italic;
      min-height: 16px;
    }
    .acuerdo-field input[type="date"] { cursor: pointer; }

    .btn-download {
      width: 100%;
      background: linear-gradient(180deg, #e81010 0%, var(--red) 100%);
      color: #fff; border: none; border-radius: 40px;
      padding: 12px 20px; font-size: 13.5px; font-weight: 700;
      font-family: 'DM Sans', sans-serif; cursor: pointer;
      display: flex; align-items: center; justify-content: center; gap: 8px;
      box-shadow: 0 4px 18px rgba(204,0,0,0.3);
      transition: filter 0.18s, transform 0.12s;
      margin-top: 22px;
    }
    .btn-download:hover { filter: brightness(1.08); }
    .btn-download:active { transform: scale(0.98); }

    /* Columna 3: vista previa del contrato */
    .acuerdos-preview-col {
      overflow-y: auto;
      background: #e8e8e6;
      display: flex;
      align-items: flex-start;
      justify-content: center;
      padding: 24px 20px;
    }

    /* ── Eventos más visibles ── */
    .event-row {
      display: flex;
      gap: 10px;
      padding: 8px 0;
      align-items: flex-start;
    }
    .event-time {
      font-size: 11px;
