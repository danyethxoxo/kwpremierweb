    // ── Número a letra (pesos mexicanos) ──
    function numeroALetra(num) {
      if (!num || isNaN(num) || num <= 0) return '';
      const UNIDADES = ['','UN','DOS','TRES','CUATRO','CINCO','SEIS','SIETE','OCHO','NUEVE',
        'DIEZ','ONCE','DOCE','TRECE','CATORCE','QUINCE','DIECISÉIS','DIECISIETE','DIECIOCHO','DIECINUEVE'];
      const DECENAS  = ['','DIEZ','VEINTE','TREINTA','CUARENTA','CINCUENTA','SESENTA','SETENTA','OCHENTA','NOVENTA'];
      const CENTENAS = ['','CIEN','DOSCIENTOS','TRESCIENTOS','CUATROCIENTOS','QUINIENTOS',
        'SEISCIENTOS','SETECIENTOS','OCHOCIENTOS','NOVECIENTOS'];

      function menos1000(n) {
        if (n === 0) return '';
        if (n === 100) return 'CIEN';
        let r = '';
        if (n >= 100) { r += CENTENAS[Math.floor(n/100)] + ' '; n %= 100; }
        if (n >= 20)  { r += DECENAS[Math.floor(n/10)]; n %= 10; if (n) r += ' Y '; }
        if (n > 0)    { r += UNIDADES[n] + ' '; }
        return r.trim();
      }

      function menos1M(n) {
        if (n === 0) return '';
        const miles = Math.floor(n / 1000);
        const resto = n % 1000;
        let r = '';
        if (miles === 1)  r = 'MIL ';
        else if (miles > 1) r = menos1000(miles) + ' MIL ';
        if (resto > 0)    r += menos1000(resto);
        return r.trim();
      }

      const entero = Math.floor(num);
      const cents  = Math.round((num - entero) * 100);
      let texto = '';

      if (entero >= 1000000) {
        const mill = Math.floor(entero / 1000000);
        const resto = entero % 1000000;
        texto += (mill === 1 ? 'UN MILLÓN' : menos1000(mill) + ' MILLONES');
        if (resto > 0) texto += ' ' + menos1M(resto);
      } else {
        texto = menos1M(entero) || 'CERO';
      }

      texto = texto.trim() + ' PESOS ' + String(cents).padStart(2,'0') + '/100 M.N.';
      return texto;
    }

