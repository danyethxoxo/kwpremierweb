    function dayStr(offset) {
      const d = new Date();
      d.setDate(d.getDate() + offset);
      return d.toISOString().split('T')[0];
    }

    function buildCalendar() {
      const container = document.getElementById('cal-container');
      if (!container) return;
      container.innerHTML = '';

      const now  = new Date();
      const hour = now.getHours();
      const DIAS = ['Domingo','Lunes','Martes','Miércoles','Jueves','Viernes','Sábado'];

      // Calcular lunes de la semana actual
      const dayOfWeek = now.getDay(); // 0=dom, 1=lun...
      const diffToMonday = dayOfWeek === 0 ? -6 : 1 - dayOfWeek;
      const monday = new Date(now);
      monday.setDate(now.getDate() + diffToMonday);

      // Solo lunes a viernes (índices 0..4)
      for (let i = 0; i < 5; i++) {
        const d = new Date(monday);
        d.setDate(monday.getDate() + i);
        const dStr = d.toISOString().split('T')[0];
        const isToday = dStr === now.toISOString().split('T')[0];
        // Abrir: si es hoy (y antes de 6pm), si son 6pm+ abrir mañana, si ya pasó el viernes abrir lunes
        const tomorrowStr = (() => { const t = new Date(now); t.setDate(t.getDate()+1); return t.toISOString().split('T')[0]; })();
        const isOpen = hour < 18 ? isToday : dStr === tomorrowStr;

        const evs = EVENTOS.filter(e => e.fecha === dStr)
                           .sort((a,b) => a.horaI.localeCompare(b.horaI));

        const wrap = document.createElement('div');
        wrap.className = 'cal-day' + (isOpen ? ' open' : '');

        const btn = document.createElement('button');
        btn.type = 'button';
        btn.className = 'cal-day-toggle' + (isToday ? ' is-today' : '');
        btn.innerHTML = `
          <div class="cal-toggle-left">
            <span class="cal-day-num">${d.getDate()}</span>
            <div>
              <div class="cal-day-name">${DIAS[d.getDay()]}</div>
              ${isToday ? '<span class="cal-today-pill">Hoy</span>' : ''}
            </div>
          </div>
          <div class="cal-toggle-right">
            <span class="cal-event-count">${evs.length} evento${evs.length !== 1 ? 's' : ''}</span>
            <span class="cal-chevron">▾</span>
          </div>`;
        btn.addEventListener('click', () => wrap.classList.toggle('open'));

        const body = document.createElement('div');
        body.className = 'cal-day-body';

        if (evs.length === 0) {
          body.innerHTML = '<div class="cal-empty">Sin eventos este día.</div>';
        } else {
          evs.forEach(ev => {
            const item = document.createElement('div');
            item.className = 'cal-event-item';
            item.innerHTML = `
              <div class="event-time">⏰ ${ev.horaI}${ev.horaF ? ' – '+ev.horaF : ''}</div>
              <div class="event-title">${ev.titulo}</div>
              ${ev.link ? `<a href="${ev.link}" target="_blank" rel="noopener" class="event-join">Únete →</a>` : ''}`;
            body.appendChild(item);
          });
        }

        wrap.appendChild(btn);
        wrap.appendChild(body);
        container.appendChild(wrap);
      }
    }

