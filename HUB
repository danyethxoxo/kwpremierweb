E html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>KW Premier — Hub</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,100..1000;1,9..40,100..1000&display=swap" rel="stylesheet" />
  <style>
    :root {
      --red: #CC0000;
      --text: #1a1a1a;
      --muted: #888;
      --bg: #EFEFEF;
      --panel: #f8f8f8;
      --card: #ffffff;
      --border: rgba(0,0,0,0.07);
      --header-h: 68px;
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    html, body {
      height: 100%;
      font-family: 'DM Sans', sans-serif;
      background: var(--bg);
      color: var(--text);
      overflow: hidden;
    }

    /* ════════════════════════════
       HEADER
    ════════════════════════════ */
    header {
      height: var(--header-h);
      background: #fff;
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 0 28px;
      border-bottom: 1px solid var(--border);
      position: relative;
      z-index: 10;
      flex-shrink: 0;
    }

    /* Logo tipográfico KW Premier */
    .logo {
      display: flex;
      flex-direction: column;
      line-height: 1;
      text-decoration: none;
      color: inherit;
      gap: 1px;
    }
    .logo-premier {
      font-size: 18px;
      font-weight: 800;
      letter-spacing: 0.12em;
      color: #8a8a8a;
    }
    .logo-kw {
      font-size: 9.5px;
      color: #aaa;
      letter-spacing: 0.06em;
    }
    .logo-kw strong { font-weight: 800; color: #999; }
    .logo-kw span   { font-weight: 400; }
    .logo-br {
      font-size: 7.5px;
      font-weight: 400;
      letter-spacing: 0.3em;
      color: #bbb;
      text-transform: uppercase;
    }

    /* CTA header */
    .header-cta {
      display: flex;
      align-items: center;
      gap: 8px;
      background: linear-gradient(180deg, #e81010 0%, var(--red) 100%);
      color: #fff;
      font-size: 13px;
      font-weight: 500;
      font-family: 'DM Sans', sans-serif;
      border: none;
      border-radius: 40px;
      padding: 5px 16px 5px 5px;
      cursor: pointer;
      text-decoration: none;
      box-shadow: 0 4px 14px rgba(204,0,0,0.28);
      transition: transform 0.18s, box-shadow 0.18s, filter 0.18s;
      white-space: nowrap;
    }
    .header-cta:hover {
      transform: translateY(-1px);
      box-shadow: 0 8px 22px rgba(204,0,0,0.38);
      filter: brightness(1.08);
    }
    .cta-circle {
      width: 26px; height: 26px;
      border-radius: 50%;
      background: rgba(255,255,255,0.22);
      display: flex; align-items: center; justify-content: center;
      flex-shrink: 0;
    }
    .cta-circle svg { width: 11px; height: 11px; }

    /* Social icons in header */
    .header-socials {
      display: flex;
      align-items: center;
      gap: 6px;
    }
    .social-btn {
      width: 32px; height: 32px;
      border-radius: 8px;
      background: #f4f4f4;
      display: flex; align-items: center; justify-content: center;
      text-decoration: none;
      color: #555;
      transition: background 0.15s, transform 0.15s;
      flex-shrink: 0;
    }
    .social-btn:hover { background: #ffe0e0; color: var(--red); transform: translateY(-1px); }
    .social-btn svg { width: 15px; height: 15px; fill: currentColor; }

    /* Day card redesign */
    .day-card {
      background: var(--card);
      border: 1px solid var(--border);
      border-radius: 14px;
      overflow: hidden;
      box-shadow: 0 1px 4px rgba(0,0,0,0.04);
      margin-bottom: 10px;
    }
    .day-card:last-child { margin-bottom: 0; }

    .day-card-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 12px 16px 10px;
      border-bottom: 1px solid rgba(0,0,0,0.05);
    }
    .day-card-header.today-hdr {
      background: var(--red);
    }
    .day-name {
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: #aaa;
    }
    .day-name.today-txt { color: rgba(255,255,255,0.75); }
    .day-number {
      font-size: 28px;
      font-weight: 800;
      color: #ddd;
      line-height: 1;
      letter-spacing: -1px;
    }
    .day-number.today-txt { color: rgba(255,255,255,0.9); }

    .day-events { padding: 10px 14px 12px; display: flex; flex-direction: column; gap: 9px; }

    .event-row {
      display: flex;
      align-items: flex-start;
      gap: 10px;
    }
    .event-time {
      font-size: 11px;
      font-weight: 700;
      color: var(--muted);
      white-space: nowrap;
      min-width: 44px;
      padding-top: 1px;
    }
    .event-info { flex: 1; min-width: 0; }
    .event-title {
      font-size: 12.5px;
      font-weight: 700;
      color: var(--text);
      line-height: 1.3;
    }
    .event-person {
      font-size: 11px;
      color: var(--muted);
      margin-top: 2px;
    }
    .event-tag {
      display: inline-block;
      font-size: 10px; font-weight: 700;
      padding: 1px 7px; border-radius: 20px;
      margin-top: 4px; letter-spacing: 0.02em;
    }
    .tag-online    { background: #e8f4ff; color: #1971C2; }
    .tag-presencial{ background: #ebfbee; color: #2F9E44; }
    .tag-ambos     { background: #f3f0ff; color: #6741D9; }
    .tag-cert      { background: #ebfbee; color: #2F9E44; }
    .tag-career    { background: #fff8e1; color: #E67700; }

    .event-join {
      display: inline-block;
      margin-top: 5px;
      font-size: 11px;
      font-weight: 700;
      color: var(--red);
      text-decoration: none;
      transition: opacity 0.15s;
    }
    .event-join:hover { opacity: 0.7; }

    .event-empty {
      font-size: 12px; color: #ccc; font-style: italic;
      padding: 4px 0;
    }

    .event-divider {
      border: none;
      border-top: 1px solid rgba(0,0,0,0.05);
      margin: 0;
    }

    /* Hamburger */
    .hamburger {
      display: none;
      flex-direction: column;
      justify-content: center;
      gap: 5px;
      width: 32px; height: 32px;
      background: none; border: none;
      cursor: pointer; z-index: 101;
    }
    .hamburger span {
      display: block; width: 22px; height: 2px;
      background: var(--text); border-radius: 2px;
      transition: transform 0.25s, opacity 0.25s;
      transform-origin: center;
    }
    .hamburger.open span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
    .hamburger.open span:nth-child(2) { opacity: 0; transform: scaleX(0); }
    .hamburger.open span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

    /* Mobile nav */
    .mobile-nav {
      position: fixed; inset: 0; background: #fff; z-index: 100;
      display: flex; flex-direction: column;
      padding: 90px 32px 40px;
      transform: translateX(100%);
      transition: transform 0.42s cubic-bezier(0.77, 0, 0.175, 1);
    }
    .mobile-nav.open { transform: translateX(0); }
    .mobile-nav ul { list-style: none; flex: 1; }
    .mobile-nav ul li { border-bottom: 1px solid rgba(0,0,0,0.07); }
    .mobile-nav ul li a {
      display: block; font-size: 32px; font-weight: 800;
      letter-spacing: -1.5px; color: var(--text);
      text-decoration: none; padding: 18px 0;
      transition: color 0.15s;
    }
    .mobile-nav ul li a:hover { color: var(--red); }
    .mobile-cta-wrap { margin-top: 28px; }
    .mobile-cta {
      display: inline-flex; align-items: center; gap: 10px;
      background: linear-gradient(180deg, #e81010 0%, var(--red) 100%);
      color: #fff; font-size: 15px; font-weight: 600;
      font-family: 'DM Sans', sans-serif;
      border: none; border-radius: 40px; padding: 7px 22px 7px 7px;
      cursor: pointer; text-decoration: none;
      box-shadow: 0 4px 18px rgba(204,0,0,0.3);
    }
    .mobile-cta .cta-circle { width: 30px; height: 30px; }

    /* ════════════════════════════
       WORKSPACE (3 columnas)
    ════════════════════════════ */
    .workspace {
      display: grid;
      grid-template-columns: 1fr 1fr 1fr 1fr;
      gap: 10px;
      padding: 10px;
      height: calc(100vh - var(--header-h));
      overflow: hidden;
    }

    .panel {
      background: var(--panel);
      border-radius: 14px;
      border: 1px solid var(--border);
      display: flex;
      flex-direction: column;
      overflow: hidden;
    }

    .panel-header {
      padding: 18px 20px 14px;
      border-bottom: 1px solid var(--border);
      flex-shrink: 0;
    }
    .panel-title {
      font-size: 12px;
      font-weight: 700;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: #aaa;
    }
    .panel-sub {
      font-size: 13px;
      font-weight: 600;
      color: var(--text);
      margin-top: 2px;
    }

    .panel-body {
      flex: 1;
      overflow-y: auto;
      padding: 14px;
      scrollbar-width: thin;
      scrollbar-color: rgba(0,0,0,0.12) transparent;
    }
    .panel-body::-webkit-scrollbar { width: 4px; }
    .panel-body::-webkit-scrollbar-thumb { background: rgba(0,0,0,0.12); border-radius: 4px; }

    /* ════════════════════════════
       PANEL 1 — Accesos directos
    ════════════════════════════ */
    .section-label {
      font-size: 10px;
      font-weight: 700;
      letter-spacing: 0.13em;
      text-transform: uppercase;
      color: #bbb;
      margin: 12px 0 8px 2px;
    }
    .section-label:first-child { margin-top: 0; }

    .card {
      background: var(--card);
      border: 1px solid var(--border);
      border-radius: 12px;
      padding: 13px 14px;
      display: flex;
      align-items: center;
      gap: 12px;
      cursor: pointer;
      text-decoration: none;
      color: inherit;
      margin-bottom: 8px;
      position: relative;
      overflow: hidden;
      box-shadow: 0 1px 4px rgba(0,0,0,0.04);
      transition: transform 0.18s ease, box-shadow 0.18s ease;
    }
    .card:last-child { margin-bottom: 0; }
    .card::after {
      content: '';
      position: absolute;
      left: 0; top: 0; bottom: 0;
      width: 3px;
      background: var(--red);
      transform: scaleY(0);
      transform-origin: center;
      transition: transform 0.2s ease;
      border-radius: 3px 0 0 3px;
    }
    .card:hover { transform: translateX(4px); box-shadow: 0 4px 14px rgba(0,0,0,0.07); }
    .card:hover::after { transform: scaleY(1); }

    .card-icon {
      width: 38px; height: 38px;
      border-radius: 10px;
      display: flex; align-items: center; justify-content: center;
      flex-shrink: 0;
    }
    .card-icon svg { width: 18px; height: 18px; }

    .card-info { flex: 1; min-width: 0; }
    .card-name { font-size: 13.5px; font-weight: 700; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .card-desc { font-size: 11px; color: var(--muted); margin-top: 1px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }

    .card-arrow {
      font-size: 18px; color: #ccc; line-height: 1;
      transition: color 0.15s, transform 0.15s;
      flex-shrink: 0;
    }
    .card:hover .card-arrow { color: var(--red); transform: translateX(2px); }

    /* ════════════════════════════
       PANEL 2 — Entrenamientos
    ════════════════════════════ */

    /* ════════════════════════════
       PANEL 3 — Próximamente
    ════════════════════════════ */
    .coming-soon {
      flex: 1;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 14px;
      padding: 32px 20px;
      text-align: center;
    }
    .coming-icon {
      width: 56px; height: 56px;
      border-radius: 16px;
      background: #f0f0f0;
      display: flex; align-items: center; justify-content: center;
    }
    .coming-icon svg { width: 26px; height: 26px; }
    .coming-title { font-size: 15px; font-weight: 700; color: #aaa; }
    .coming-desc { font-size: 12px; color: #ccc; line-height: 1.6; max-width: 200px; }

    /* ════════════════════════════
       MODAL CONTRATOS
    ════════════════════════════ */
    .overlay {
      display: none;
      position: fixed; inset: 0;
      background: rgba(0,0,0,0.4);
      backdrop-filter: blur(4px);
      z-index: 200;
      align-items: center; justify-content: center;
      padding: 20px;
    }
    .overlay.open { display: flex; }

    .modal {
      background: #fff;
      border-radius: 20px;
      padding: 28px;
      width: 100%; max-width: 480px;
      position: relative;
      box-shadow: 0 24px 60px rgba(0,0,0,0.16);
      animation: pop-in 0.22s ease;
    }
    @keyframes pop-in {
      from { opacity: 0; transform: scale(0.94) translateY(10px); }
      to   { opacity: 1; transform: scale(1) translateY(0); }
    }
    .modal-close {
      position: absolute; top: 14px; right: 14px;
      width: 28px; height: 28px; border-radius: 50%;
      border: none; background: #f0f0f0; cursor: pointer;
      display: flex; align-items: center; justify-content: center;
      font-size: 14px; color: #666;
      transition: background 0.15s, color 0.15s;
    }
    .modal-close:hover { background: #ffe0e0; color: var(--red); }

    .modal-head {
      display: flex; align-items: center; gap: 12px;
      margin-bottom: 22px;
    }
    .modal-head-icon {
      width: 42px; height: 42px; border-radius: 11px;
      background: #fff0f0;
      display: flex; align-items: center; justify-content: center;
    }
    .modal-head-icon svg { width: 22px; height: 22px; }
    .modal-head-title { font-size: 1.1rem; font-weight: 800; }
    .modal-head-sub { font-size: 12px; color: var(--muted); margin-top: 1px; }

    .modal-group { margin-bottom: 16px; }
    .modal-group:last-child { margin-bottom: 0; }
    .modal-group-label {
      font-size: 10px; font-weight: 700;
      letter-spacing: 0.1em; text-transform: uppercase;
      color: #aaa; margin-bottom: 8px;
    }
    .modal-links { display: flex; flex-direction: column; gap: 7px; }
    .modal-link {
      display: flex; align-items: center; gap: 11px;
      padding: 12px 14px; border-radius: 11px;
      border: 1.5px solid var(--border);
      text-decoration: none; color: var(--text);
      font-size: 13.5px; font-weight: 600;
      transition: border-color 0.15s, background 0.15s, box-shadow 0.15s;
    }
    .modal-link:hover {
      border-color: var(--red);
      background: #fff8f8;
      box-shadow: 0 2px 10px rgba(204,0,0,0.08);
    }
    .modal-link-icon {
      width: 32px; height: 32px; border-radius: 8px;
      display: flex; align-items: center; justify-content: center; flex-shrink: 0;
    }
    .modal-link-icon svg { width: 15px; height: 15px; }
    .modal-link-arrow { margin-left: auto; color: #ccc; font-size: 15px; }
    .modal-divider { border: none; border-top: 1px solid var(--border); margin: 14px 0; }

    /* ════════════════════════════
       MODAL TICKET
    ════════════════════════════ */
    .modal-ticket { max-width: 500px; }

    .ticket-form { display: flex; flex-direction: column; gap: 14px; }

    .form-group { display: flex; flex-direction: column; gap: 5px; }

    .form-group label {
      font-size: 11px; font-weight: 700;
      letter-spacing: 0.06em; text-transform: uppercase;
      color: #aaa;
    }

    .form-group input,
    .form-group textarea {
      padding: 10px 12px;
      border: 1.5px solid var(--border);
      border-radius: 10px;
      font-size: 13.5px;
      font-family: 'DM Sans', sans-serif;
      color: var(--text);
      background: var(--bg);
      transition: border-color 0.15s, box-shadow 0.15s;
      outline: none;
    }

    .form-group input:focus,
    .form-group textarea:focus {
      border-color: #1971C2;
      box-shadow: 0 0 0 3px rgba(25,113,194,0.1);
      background: #fff;
    }

    .form-group textarea { resize: vertical; min-height: 90px; }

    .urgency-options { display: grid; grid-template-columns: repeat(3,1fr); gap: 7px; }

    .urgency-option input[type="radio"] { display: none; }

    .urgency-option label {
      display: flex; align-items: center; justify-content: center; gap: 5px;
      padding: 8px 6px;
      border: 1.5px solid var(--border);
      border-radius: 9px;
      font-size: 12px; font-weight: 700;
      cursor: pointer; letter-spacing: 0;
      text-transform: none;
      transition: all 0.15s;
      background: var(--bg);
      color: var(--text);
    }

    .urgency-baja  input:checked + label { background: #2F9E44; border-color: #2F9E44; color: #fff; }
    .urgency-media input:checked + label { background: #E67700; border-color: #E67700; color: #fff; }
    .urgency-alta  input:checked + label { background: #C92A2A; border-color: #C92A2A; color: #fff; }

    .urgency-option label:hover { border-color: #bbb; background: #fff; }

    .btn-ticket-submit {
      background: linear-gradient(180deg, #228be6 0%, #1971C2 100%);
      color: #fff; border: none; border-radius: 40px;
      padding: 11px 22px;
      font-size: 13.5px; font-weight: 600;
      font-family: 'DM Sans', sans-serif;
      cursor: pointer; display: flex; align-items: center; justify-content: center; gap: 8px;
      box-shadow: 0 4px 14px rgba(25,113,194,0.3);
      transition: filter 0.18s, transform 0.12s;
      margin-top: 4px;
    }
    .btn-ticket-submit:hover { filter: brightness(1.08); }
    .btn-ticket-submit:active { transform: scale(0.98); }
    .btn-ticket-submit:disabled { background: #adb5bd; box-shadow: none; cursor: not-allowed; transform: none; }

    .spinner {
      width: 15px; height: 15px;
      border: 2px solid rgba(255,255,255,0.4);
      border-top-color: #fff;
      border-radius: 50%;
      animation: spin 0.7s linear infinite;
    }
    @keyframes spin { to { transform: rotate(360deg); } }

    .ticket-toast {
      display: none; align-items: flex-start; gap: 10px;
      padding: 12px 14px; border-radius: 10px;
      font-size: 12.5px; line-height: 1.5;
    }
    .ticket-toast.success { display: flex; background: #ebfbee; border: 1.5px solid #8ce99a; color: #2F9E44; }
    .ticket-toast.error   { display: flex; background: #fff5f5; border: 1.5px solid #ffa8a8; color: #C92A2A; }
    .ticket-toast svg { width: 16px; height: 16px; flex-shrink: 0; margin-top: 1px; }

    /* ════════════════════════════
       RESPONSIVE
    ════════════════════════════ */
    @media (max-width: 1200px) and (min-width: 901px) {
      .workspace { grid-template-columns: 1fr 1fr; }
    }
    @media (max-width: 900px) {
      html, body { overflow: auto; }
      .workspace {
        grid-template-columns: 1fr;
        height: auto;
        overflow: visible;
      }
      .panel { min-height: 420px; }
      .panel-body { overflow: visible; }
      .hamburger { display: flex; }
      .header-cta { display: none; }
    }

    /* ════ CALENDARIO DESPLEGABLE ════ */
    .cal-week-label {
      font-size: 10px; font-weight: 700; letter-spacing: 0.13em;
      text-transform: uppercase; color: #bbb;
      margin: 0 0 8px 2px;
    }

    .cal-day {
      background: var(--card);
      border: 1px solid var(--border);
      border-radius: 12px;
      overflow: hidden;
      margin-bottom: 7px;
      box-shadow: 0 1px 4px rgba(0,0,0,0.03);
    }
    .cal-day:last-child { margin-bottom: 0; }

    .cal-day-toggle {
      width: 100%;
      display: flex; align-items: center; justify-content: space-between;
      padding: 11px 14px;
      background: none; border: none; cursor: pointer;
      font-family: 'DM Sans', sans-serif;
      text-align: left;
      transition: background 0.12s;
    }
    .cal-day-toggle:hover { background: rgba(0,0,0,0.02); }

    .cal-day-toggle.is-today { background: var(--red); }
    .cal-day-toggle.is-today:hover { background: #b50000; }

    .cal-toggle-left { display: flex; align-items: center; gap: 10px; }

    .cal-day-num {
      font-size: 22px; font-weight: 800; line-height: 1;
      color: #ddd; letter-spacing: -0.5px;
    }
    .cal-day-toggle.is-today .cal-day-num { color: rgba(255,255,255,0.85); }

    .cal-day-name {
      font-size: 11px; font-weight: 700;
      letter-spacing: 0.1em; text-transform: uppercase; color: #aaa;
    }
    .cal-day-toggle.is-today .cal-day-name { color: rgba(255,255,255,0.7); }

    .cal-today-pill {
      font-size: 9.5px; font-weight: 700;
      background: rgba(255,255,255,0.22);
      color: #fff; padding: 2px 7px; border-radius: 20px;
      letter-spacing: 0.06em; text-transform: uppercase;
    }

    .cal-toggle-right { display: flex; align-items: center; gap: 8px; }

    .cal-event-count {
      font-size: 11px; color: #bbb;
    }
    .cal-day-toggle.is-today .cal-event-count { color: rgba(255,255,255,0.6); }

    .cal-chevron {
      font-size: 11px; color: #ccc;
      transition: transform 0.22s ease;
      display: inline-block;
    }
    .cal-day-toggle.is-today .cal-chevron { color: rgba(255,255,255,0.6); }
    .cal-day.open .cal-chevron { transform: rotate(180deg); }

    .cal-day-body {
      display: none;
      border-top: 1px solid rgba(0,0,0,0.05);
      padding: 10px 14px 12px;
    }
    .cal-day.open .cal-day-body { display: block; }

    .cal-empty {
      font-size: 12px; color: #ccc; font-style: italic; padding: 4px 0;
    }

    /* ════ SALAS COMING SOON ════ */
    .salas-coming {
      background: var(--card);
      border: 1.5px dashed rgba(0,0,0,0.09);
      border-radius: 12px;
      padding: 20px 16px;
      text-align: center;
      margin-bottom: 14px;
    }
    .salas-coming-icon { font-size: 26px; margin-bottom: 6px; }
    .salas-coming-title { font-size: 13px; font-weight: 700; color: #aaa; margin-bottom: 3px; }
    .salas-coming-desc { font-size: 11px; color: #ccc; line-height: 1.5; }

    /* ════ FORMULARIO SALAS ════ */
    .sala-form { display: flex; flex-direction: column; gap: 10px; }

    .sala-form .form-group label {
      font-size: 10px; font-weight: 700;
      letter-spacing: 0.1em; text-transform: uppercase; color: #bbb;
    }

    .sala-form .form-group input,
    .sala-form .form-group select {
      padding: 9px 11px;
      border: 1.5px solid var(--border);
      border-radius: 10px;
      font-size: 13px; font-family: 'DM Sans', sans-serif;
      color: var(--text); background: #fff;
      transition: border-color 0.15s, box-shadow 0.15s;
      outline: none; width: 100%;
    }
    .sala-form .form-group input:focus,
    .sala-form .form-group select:focus {
      border-color: #7048E8;
      box-shadow: 0 0 0 3px rgba(112,72,232,0.09);
    }

    .btn-sala {
      background: linear-gradient(180deg, #845ef7 0%, #7048E8 100%);
      color: #fff; border: none; border-radius: 40px;
      padding: 10px 20px; font-size: 13px; font-weight: 600;
      font-family: 'DM Sans', sans-serif; cursor: pointer;
      display: flex; align-items: center; justify-content: center; gap: 7px;
      box-shadow: 0 4px 14px rgba(112,72,232,0.25);
      transition: filter 0.18s, transform 0.12s; width: 100%;
    }
    .btn-sala:hover { filter: brightness(1.08); }
    .btn-sala:active { transform: scale(0.98); }

    .sala-toast {
      display: none; align-items: flex-start; gap: 10px;
      padding: 10px 12px; border-radius: 10px;
      font-size: 12px; line-height: 1.5;
    }
    .sala-toast.success { display: flex; background: #f3f0ff; border: 1.5px solid #b197fc; color: #5f3dc4; }
    .sala-toast.error   { display: flex; background: #fff5f5; border: 1.5px solid #ffa8a8; color: #C92A2A; }
    .sala-toast svg { width: 15px; height: 15px; flex-shrink: 0; margin-top: 1px; }

    /* ════ FORMULARIO TICKETS INLINE ════ */
    .ticket-inline { display: flex; flex-direction: column; gap: 12px; }

    .ticket-inline .form-group label {
      font-size: 10px; font-weight: 700;
      letter-spacing: 0.1em; text-transform: uppercase; color: #bbb;
    }

    .ticket-inline .form-group input,
    .ticket-inline .form-group select,
    .ticket-inline .form-group textarea {
      padding: 9px 11px;
      border: 1.5px solid var(--border);
      border-radius: 10px;
      font-size: 13px; font-family: 'DM Sans', sans-serif;
      color: var(--text); background: #fff;
      transition: border-color 0.15s, box-shadow 0.15s;
      outline: none; width: 100%;
    }
    .ticket-inline .form-group input:focus,
    .ticket-inline .form-group select:focus,
    .ticket-inline .form-group textarea:focus {
      border-color: #1971C2;
      box-shadow: 0 0 0 3px rgba(25,113,194,0.09);
    }
    .ticket-inline .form-group textarea { resize: vertical; min-height: 75px; }

    .ticket-inline .urgency-options { display: grid; grid-template-columns: repeat(3,1fr); gap: 6px; }
    .ticket-inline .urgency-option input[type="radio"] { display: none; }
    .ticket-inline .urgency-option label {
      display: flex; align-items: center; justify-content: center; gap: 4px;
      padding: 7px 4px; border: 1.5px solid var(--border); border-radius: 9px;
      font-size: 11.5px; font-weight: 700; cursor: pointer;
      letter-spacing: 0; text-transform: none;
      transition: all 0.15s; background: var(--bg); color: var(--text);
    }
    .ticket-inline .urgency-baja  input:checked + label { background: #2F9E44; border-color: #2F9E44; color: #fff; }
    .ticket-inline .urgency-media input:checked + label { background: #E67700; border-color: #E67700; color: #fff; }
    .ticket-inline .urgency-alta  input:checked + label { background: #C92A2A; border-color: #C92A2A; color: #fff; }
    .ticket-inline .urgency-option label:hover { border-color: #bbb; background: #fff; }

    .btn-ticket-inline {
      background: linear-gradient(180deg, #228be6 0%, #1971C2 100%);
      color: #fff; border: none; border-radius: 40px;
      padding: 10px 20px; font-size: 13px; font-weight: 600;
      font-family: 'DM Sans', sans-serif; cursor: pointer;
      display: flex; align-items: center; justify-content: center; gap: 7px;
      box-shadow: 0 4px 14px rgba(25,113,194,0.28);
      transition: filter 0.18s, transform 0.12s; width: 100%;
    }
    .btn-ticket-inline:hover { filter: brightness(1.08); }
    .btn-ticket-inline:active { transform: scale(0.98); }
    .btn-ticket-inline:disabled { background: #adb5bd; box-shadow: none; cursor: not-allowed; }

    .ticket-inline-toast {
      display: none; align-items: flex-start; gap: 10px;
      padding: 10px 12px; border-radius: 10px;
      font-size: 12px; line-height: 1.5;
    }
    .ticket-inline-toast.success { display: flex; background: #ebfbee; border: 1.5px solid #8ce99a; color: #2F9E44; }
    .ticket-inline-toast.error   { display: flex; background: #fff5f5; border: 1.5px solid #ffa8a8; color: #C92A2A; }
    .ticket-inline-toast svg { width: 15px; height: 15px; flex-shrink: 0; margin-top: 1px; }

