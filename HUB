    function getPF(id) { const el = document.getElementById(id); return el ? el.value : ''; }

    function fmtPeso(n) {
      const num = parseFloat(n)||0;
      return '$'+num.toLocaleString('es-MX',{minimumFractionDigits:2})+' M.N.';
    }
    function fmtPesoLetra(n) {
      const num = parseFloat(n)||0;
      if(num===0) return 'CERO 00/100 PESOS MEXICANOS';
      try { return numeroALetra(num).toUpperCase()+' 00/100 PESOS MEXICANOS'; } catch(e) { return num.toLocaleString('es-MX')+' 00/100 PESOS MEXICANOS'; }
    }
    function fmtDateLong(dateStr) {
      if(!dateStr) return '_____________________';
      const d = new Date(dateStr+'T12:00:00');
      return d.toLocaleDateString('es-MX',{day:'numeric',month:'long',year:'numeric'}).toUpperCase();
