    async function downloadExtraWord() {
      const id = currentAcuerdo;
      const cfg = ACUERDOS_EXTRA[id];
      if (!cfg) return;

      if (typeof docx === 'undefined') {
        alert('La librería de Word no cargó. Verifica tu conexión e intenta de nuevo.');
        return;
      }

      const { Document, Packer, Paragraph, TextRun, Table, TableRow, TableCell,
              ImageRun, AlignmentType, BorderStyle, WidthType } = docx;

      const v = getExtraValues(id);
      const logoData = Uint8Array.from(atob(''), c => c.charCodeAt(0));

      function txt(text, opts={}) { return new TextRun({text:String(text||''),font:'Arial',size:20,...opts}); }
      function bld(text, opts={}) { return txt(text,{bold:true,...opts}); }
      function cW(val, placeholder) { return val&&val.toString().trim() ? bld(val.toString().trim()) : txt(placeholder,{bold:true,underline:{}}); }
      function par(children, opts={}) { return new Paragraph({children,alignment:AlignmentType.JUSTIFIED,spacing:{after:80},...opts}); }
      function sec(text) { return new Paragraph({children:[new TextRun({text,font:'Arial',size:20,bold:true,underline:{}})],spacing:{before:120,after:60}}); }
      function fF(iso) {
        if(!iso) return '_____________________';
        const [y,m,d]=iso.split('-').map(Number);
        const M=['','enero','febrero','marzo','abril','mayo','junio','julio','agosto','septiembre','octubre','noviembre','diciembre'];
        return `${d} de ${M[m]} de ${y}`;
      }
      function firmaCell(children) {
        return new TableCell({
          width:{size:4320,type:WidthType.DXA},
          margins:{top:600,bottom:100,left:60,right:60},
          borders:{top:{style:BorderStyle.SINGLE,size:4,color:'000000'},bottom:{style:BorderStyle.NONE,size:0,color:'FFFFFF'},left:{style:BorderStyle.NONE,size:0,color:'FFFFFF'},right:{style:BorderStyle.NONE,size:0,color:'FFFFFF'}},
          children:[new Paragraph({alignment:AlignmentType.CENTER,spacing:{before:80,after:0},children})]
        });
      }
      function spacerCell() {
        return new TableCell({width:{size:720,type:WidthType.DXA},borders:{top:{style:BorderStyle.NONE,size:0,color:'FFFFFF'},bottom:{style:BorderStyle.NONE,size:0,color:'FFFFFF'},left:{style:BorderStyle.NONE,size:0,color:'FFFFFF'},right:{style:BorderStyle.NONE,size:0,color:'FFFFFF'}},children:[new Paragraph({children:[]})]});
      }
      function firmaRow(col1Children, col2Children) {
        return new TableRow({children:[firmaCell(col1Children),spacerCell(),firmaCell(col2Children)]});
      }
      function firmaTable(rows) {
        return new Table({width:{size:9360,type:WidthType.DXA},columnWidths:[4320,720,4320],borders:{top:{style:BorderStyle.NONE,size:0,color:'FFFFFF'},bottom:{style:BorderStyle.NONE,size:0,color:'FFFFFF'},left:{style:BorderStyle.NONE,size:0,color:'FFFFFF'},right:{style:BorderStyle.NONE,size:0,color:'FFFFFF'},insideHorizontal:{style:BorderStyle.NONE,size:0,color:'FFFFFF'},insideVertical:{style:BorderStyle.NONE,size:0,color:'FFFFFF'}},rows});
      }

      // Construir contenido según el acuerdo
      let children = [
        new Paragraph({children:[new ImageRun({data:logoData,transformation:{width:120,height:47},type:'png'})],spacing:{after:160}}),
      ];

      const titulo = cfg.titulo.toUpperCase();
      children.push(new Paragraph({children:[new TextRun({text:titulo,font:'Arial',size:22,bold:true,underline:{}})],alignment:AlignmentType.CENTER,spacing:{after:160}}));

      // Contenido genérico: campos del formulario como párrafos
      cfg.campos.forEach(f => {
        const val = v[f.id] || '';
        if (val.trim()) {
          children.push(par([bld(f.label.toUpperCase()+': '), txt(val)]));
        } else {
          children.push(par([bld(f.label.toUpperCase()+': '), txt('_________________________',{underline:{}})]));
        }
      });

      // Firma genérica
      children.push(new Paragraph({spacing:{before:400,after:0}}));
      children.push(firmaTable([
        firmaRow(
          [txt('Nombre y Firma',{size:18})],
          [bld('GUSTAVO SOLARES CAMPOS',{size:18}), new TextRun({break:1}), txt('INMUEBLES VALLE PREMIUM, S.A.P.I. DE C.V.',{size:18})]
        )
      ]));

      let blob;
      try {
        const docFile = new Document({sections:[{properties:{page:{size:{width:12240,height:15840},margin:{top:1200,right:1080,bottom:940,left:720}}},children}]});
        blob = await Packer.toBlob(docFile);
      } catch(err) {
        alert('Error al generar Word: ' + err.message);
        return;
      }
      const url = URL.createObjectURL(blob);
      const a = document.createElement('a');
      a.href = url;
      a.download = cfg.titulo.replace(/[^a-zA-Z0-9 ]/g,'').replace(/\s+/g,'_') + '.docx';
      a.click();
      URL.revokeObjectURL(url);
    }


